filters:
  and:
    - or:
        - file.inFolder("post")
        - file.inFolder("deck")
        - file.inFolder("link")
        - file.inFolder("project")
        - file.inFolder("social-post")
        - file.inFolder("newsletter")
    - status != "published"
views:
  - type: table
    name: Pipeline
    groupBy:
      property: status
      direction: ASC
    order:
      - file.name
      - file.folder
      - status

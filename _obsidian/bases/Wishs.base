filters:
  and:
    - file.inFolder("wish")
views:
  - type: table
    name: All Wishs
    order:
      - file.name
      - title
      - status
      - priority
      - requested
      - tags
      - declinedReason
  - type: table
    name: By Status
    groupBy:
      property: status
      direction: ASC
    order:
      - file.name
      - title
      - status
      - priority
      - requested
      - tags
      - declinedReason
